{
  "name": "spice-etrade",
  "productName": "Spice e-Trade",
  "version": "1.0.0",
  "description": "Spice e-Trade \u2014 admin app for invoices, payments, and exports (e-Trade only)",
  "author": "Vinoth",
  "main": "electron/main.js",
  "scripts": {
    "start": "node server.js",
    "start:electron": "electron .",
    "build": "electron-builder --publish never",
    "build:mac": "electron-builder --mac --publish never",
    "build:win": "electron-builder --win --publish never",
    "build:win:release": "electron-builder --win --publish always",
    "build:mac:release": "electron-builder --mac --publish always"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "call-bind-apply-helpers": "^1.0.2",
    "cors": "^2.8.5",
    "dbffile": "^1.12.0",
    "dotenv": "^16.4.5",
    "es-set-tostringtag": "^2.0.3",
    "exceljs": "^4.4.0",
    "express": "^4.21.0",
    "express-rate-limit": "^8.5.0",
    "multer": "^2.1.1",
    "pdfkit": "^0.15.0",
    "side-channel-list": "^1.0.0",
    "side-channel-map": "^1.0.1",
    "side-channel-weakmap": "^1.0.2",
    "sql.js": "^1.10.3",
    "xlsx": "^0.18.5"
  },
  "optionalDependencies": {
    "better-sqlite3": "^11.7.0"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^25.0.0",
    "electron-updater": "^6.3.0"
  },
  "build": {
    "appId": "com.vinoth.spice-etrade",
    "productName": "Spice e-Trade",
    "copyright": "\u00a9 2026",
    "files": [
      "electron/**/*",
      "public/**/*",
      "*.js",
      "package.json",
      "node_modules/**/*",
      "!**/*.map",
      "!**/test/**",
      "!**/tests/**",
      "!**/__tests__/**",
      "!**/.bin/**",
      "!**/{.eslintrc,.eslintrc.json,.eslintrc.js,.eslintignore,.editorconfig,.nycrc,.travis.yml,.appveyor.yml,.github,.babelrc,tsconfig.json}",
      "!data",
      "!data/**/*",
      "!.git",
      "!dist-electron",
      "!dist"
    ],
    "asar": false,
    "afterPack": "./electron/after-pack.js",
    "extraResources": [
      {
        "from": "node_modules/sql.js/dist/sql-wasm.wasm",
        "to": "sql-wasm.wasm"
      }
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "category": "public.app-category.business",
      "artifactName": "SpiceETrade-${version}-${arch}.${ext}",
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "identity": null
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "SpiceETrade-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Spice e-Trade"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "siddhajo",
        "repo": "spice-eTrade-VST"
      }
    ]
  }
}
