{
  "appId": "com.vinoth.spice-etrade",
  "productName": "Spice e-Trade",
  "copyright": "© 2026",
  "files": [
    "electron/**/*",
    "public/**/*",
    "*.js",
    "package.json",
    "node_modules/**/*",
    "!**/*.map",
    "!**/test/**",
    "!**/tests/**",
    "!**/__tests__/**",
    "!**/.bin/**",
    "!**/{.eslintrc,.eslintrc.json,.eslintrc.js,.eslintignore,.editorconfig,.nycrc,.travis.yml,.appveyor.yml,.github,.babelrc,tsconfig.json}",
    "!data",
    "!data/**/*",
    "!.git",
    "!dist-electron",
    "!dist"
  ],
  "asar": false,
  "afterPack": "./electron/after-pack.js",
  "extraResources": [
    {
      "from": "node_modules/sql.js/dist/sql-wasm.wasm",
      "to": "sql-wasm.wasm"
    }
  ],
  "mac": {
    "target": [
      {
        "target": "dmg",
        "arch": [
          "arm64",
          "x64"
        ]
      },
      {
        "target": "zip",
        "arch": [
          "arm64",
          "x64"
        ]
      }
    ],
    "category": "public.app-category.business",
    "artifactName": "SpiceETrade-${version}-${arch}.${ext}",
    "hardenedRuntime": false,
    "gatekeeperAssess": false,
    "identity": null
  },
  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": [
          "x64"
        ]
      }
    ],
    "artifactName": "SpiceETrade-Setup-${version}.${ext}"
  },
  "nsis": {
    "oneClick": false,
    "perMachine": false,
    "allowElevation": true,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "shortcutName": "Spice e-Trade"
  },
  "publish": [
    {
      "provider": "github",
      "owner": "siddhajo",
      "repo": "spice-eTrade-VST"
    }
  ]
}
